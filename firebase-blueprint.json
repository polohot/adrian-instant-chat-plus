{
  "entities": {
    "Room": {
      "title": "Chat Room",
      "description": "A persistent chat room identified by a unique ID.",
      "type": "object",
      "properties": {
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the room was created."
        },
        "name": {
          "type": "string",
          "description": "Optional name for the room."
        }
      },
      "required": ["createdAt"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A message sent within a chat room.",
      "type": "object",
      "properties": {
        "sender": {
          "type": "string",
          "description": "The username of the sender."
        },
        "text": {
          "type": "string",
          "description": "The text content of the message (Markdown supported)."
        },
        "imageUrl": {
          "type": "string",
          "description": "Optional base64 encoded image or URL."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was sent."
        }
      },
      "required": ["sender", "timestamp"]
    }
  },
  "firestore": {
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "Collection of chat rooms."
    },
    "/rooms/{roomId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Subcollection of messages within a room."
    }
  }
}
